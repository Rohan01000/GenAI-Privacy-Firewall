# ── GenAI Privacy Firewall — Environment Variables ────────────────────────────
# Copy this to .env and edit as needed.

# Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434

# Default model to use when none is specified in the request
DEFAULT_MODEL=llama3

# Server bind settings
HOST=0.0.0.0
PORT=8000

# Requests per minute per IP before 429 is returned
RATE_LIMIT_PER_MIN=60

# Path to trained model directory (relative to project root)
MODEL_DIR=model/saved

# Minimum confidence threshold for redaction (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.80

# "scratch" = BiLSTM-CRF, "regex" = regex-only fallback
MODEL_TYPE=scratch
